#!/bin/sh

# 1. Monitör ayarları (Xrandr ile)
# Eğer tek monitör kullanıyorsan buna gerek yok, ama 180Hz değerini sabitleyelim:
xrandr --output DisplayPort-0 --mode 1920x1080 --rate 180.00

# 2. Panel ve Estetik (Sistemi kirletmeden)
# Picom (saydamlık ve gölge) - arka planda çalıştır
pgrep -x picom >/dev/null || picom -b &

# 3. BSPWM Ayarları
bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2
bspc config window_gap          10

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true

# Renkler (Pop!_OS estetiğine uygun koyu tema)
bspc config normal_border_color  "#44475a"
bspc config active_border_color  "#6272a4"
bspc config focused_border_color "#bd93f9"

# 4. Kural Setleri (Bazı uygulamalar tiling yapmasın)
bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Firefox desktop='^2'
bspc rule -a Steam desktop='^10'

# 5. Kısayol yöneticisini başlat
sxhkd &

# Panel başlat
~/.config/polybar/launch.sh &

# bspwmrc dosyanın sonuna ekle:
bspc config pointer_modifier mod1
bspc config pointer_action1 move
bspc config pointer_action2 resize_side
